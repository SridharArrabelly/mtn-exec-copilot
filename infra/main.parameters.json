{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": { "value": "${AZURE_ENV_NAME}" },
    "location":        { "value": "${AZURE_LOCATION}" },
    "foundryLocation": { "value": "${FOUNDRY_LOCATION=}" },
    "resourceGroupName": { "value": "${AZURE_RESOURCE_GROUP_NAME}" },
    "principalId":     { "value": "${AZURE_PRINCIPAL_ID=}" },

    "foundryAccountName":     { "value": "${FOUNDRY_ACCOUNT_NAME=}" },
    "foundryResourceGroup":   { "value": "${FOUNDRY_RESOURCE_GROUP=}" },
    "foundryProjectEndpoint": { "value": "${FOUNDRY_PROJECT_ENDPOINT=}" },

    "searchServiceName":   { "value": "${SEARCH_SERVICE_NAME=}" },
    "searchResourceGroup": { "value": "${SEARCH_RESOURCE_GROUP=}" },

    "appInsightsName":          { "value": "${APPINSIGHTS_NAME=}" },
    "appInsightsResourceGroup": { "value": "${APPINSIGHTS_RESOURCE_GROUP=}" },

    "agentName":           { "value": "${AGENT_NAME=AvatarAgent}" },
    "agentProjectName":    { "value": "${AGENT_PROJECT_NAME=avatar-forge}" },
    "searchConnectionName":{ "value": "${SEARCH_CONNECTION_NAME=aisearch-connection}" },
    "searchIndexName":     { "value": "${SEARCH_INDEX_NAME=knowledge-index}" },
    "voiceLiveVoice":      { "value": "${VOICELIVE_VOICE=en-US-AvaMultilingualNeural}" },
    "bingConnectionName":  { "value": "${BING_CONNECTION_NAME=}" },
    "bingCustomConfigName":{ "value": "${BING_CUSTOM_CONFIG_NAME=}" },

    "agentModel":             { "value": "${AGENT_MODEL=gpt-5.4}" },
    "embeddingDeployment":    { "value": "${EMBEDDING_DEPLOYMENT=text-embedding-3-small}" },
    "avatarName":             { "value": "${AVATAR_NAME=Lisa-casual-sitting}" },
    "customAvatarName":       { "value": "${CUSTOM_AVATAR_NAME=}" },
    "avatarDisplayName":      { "value": "${AVATAR_DISPLAY_NAME=}" },
    "photoAvatarName":        { "value": "${PHOTO_AVATAR_NAME=}" },
    "isPhotoAvatar":          { "value": "${IS_PHOTO_AVATAR=true}" },
    "isCustomAvatar":         { "value": "${IS_CUSTOM_AVATAR=true}" },
    "avatarBackgroundImageUrl": { "value": "${AVATAR_BACKGROUND_IMAGE_URL=}" },
    "srModel":             { "value": "${SR_MODEL=mai-transcribe-1}" },
    "recognitionLanguage": { "value": "${RECOGNITION_LANGUAGE=auto}" },

    "modelName":           { "value": "${MODEL_NAME=gpt-5.4}" },
    "modelVersion":        { "value": "${MODEL_VERSION=2026-03-05}" },
    "modelDeploymentName": { "value": "${MODEL_DEPLOYMENT_NAME=gpt-5.4}" },
    "modelSkuName":        { "value": "${MODEL_SKU_NAME=GlobalStandard}" },
    "modelCapacity":       { "value": 50 },

    "botAppId":        { "value": "${BOT_APP_ID=}" },
    "botAppTenantId":  { "value": "${BOT_APP_TENANT_ID=}" },
    "botAppPassword":  { "value": "${BOT_APP_PASSWORD=}" },
    "botDisplayName":  { "value": "${BOT_DISPLAY_NAME=Avatar Forge}" },
    "teamsAppId":      { "value": "${TEAMS_APP_ID=}" },
    "agentId":         { "value": "${AGENT_ID=}" }
  }
}
