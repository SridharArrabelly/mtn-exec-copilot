{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "{{VERSION}}",
  "id": "{{APP_ID}}",
  "developer": {
    "name": "Avatar Forge",
    "websiteUrl": "https://github.com/SridharArrabelly/avatar-forge",
    "privacyUrl": "https://github.com/SridharArrabelly/avatar-forge/blob/main/README.md",
    "termsOfUseUrl": "https://github.com/SridharArrabelly/avatar-forge/blob/main/LICENSE"
  },
  "name": {
    "short": "{{APP_NAME}}",
    "full": "{{APP_FULL_NAME}}"
  },
  "description": {
    "short": "{{APP_DESC_SHORT}}",
    "full": "{{APP_DESC_FULL}}"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#5B5FC7",
  "staticTabs": [
    {
      "entityId": "avatarForgeHome",
      "name": "Avatar",
      "contentUrl": "https://{{HOSTNAME}}/?inTeams=1",
      "websiteUrl": "https://{{HOSTNAME}}/",
      "scopes": [
        "personal"
      ]
    }
  ],
  "configurableTabs": [
    {
      "configurationUrl": "https://{{HOSTNAME}}/companion-config.html?inTeams=1",
      "canUpdateConfiguration": false,
      "scopes": [
        "groupChat"
      ],
      "context": [
        "meetingSidePanel",
        "meetingStage",
        "meetingChatTab"
      ]
    }
  ],
  "bots": [
    {
      "botId": "{{BOT_ID}}",
      "scopes": [
        "personal",
        "team",
        "groupchat"
      ],
      "isNotificationOnly": false,
      "supportsFiles": false,
      "supportsCalling": false,
      "supportsVideo": false,
      "commandLists": [
        {
          "scopes": [
            "personal",
            "team",
            "groupchat"
          ],
          "commands": [
            {
              "title": "Ask a question",
              "description": "Ask the knowledge base anything; I answer with sources."
            },
            {
              "title": "Open the live avatar",
              "description": "Get a link to the rich, real-time avatar tab."
            }
          ]
        }
      ]
    }
  ],
  "devicePermissions": [
    "media"
  ],
  "validDomains": [
    "{{HOSTNAME}}",
    "token.botframework.com"
  ]
}
