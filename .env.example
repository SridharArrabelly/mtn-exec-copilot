# --- Required: Voice Live / Foundry ---
AZURE_VOICELIVE_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/
AGENT_NAME=MtnAvatarAgent
AGENT_PROJECT_NAME=mtn-execu-bot
PROJECT_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/api/projects/<project-name>
VOICELIVE_VOICE=en-US-AvaMultilingualNeural

# --- Authentication ---
# Voice Live agent-v2 sessions require Microsoft Entra ID (AAD). API key auth
# is NOT supported for the agent WebSocket path used by this app, so the
# backend always uses DefaultAzureCredential.
#
# Local host (no Docker):  run `az login` - DefaultAzureCredential picks it
#                          up via AzureCliCredential.
#
# Azure (`azd up`):        the Container App uses a user-assigned managed
#                          identity provisioned by the infra. Nothing to set
#                          here. This is the recommended path.
#
# Local Docker:            NOT recommended. The image has no az CLI, no
#                          IMDS, and SP client secrets are typically blocked
#                          by tenant app-management policy (see README
#                          "Authentication inside the container"). If your
#                          tenant DOES allow SP secrets, you can set:
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# Optional: skip the IMDS managed-identity probe in DefaultAzureCredential.
# Set to "true" on a developer laptop to cut startup pre-warm from ~7s to
# ~1.5s. DefaultAzureCredential normally tries ManagedIdentityCredential
# first and waits ~5s for the IMDS endpoint at 169.254.169.254 to time out
# before falling through to AzureCliCredential. Off-Azure that probe never
# succeeds, so skipping it is pure win.
# IMPORTANT: leave UNSET (or "false") in Azure-hosted environments —
# Container Apps, App Service, and AKS workload identity all need the
# managed-identity path enabled.
# AUTH_EXCLUDE_MANAGED_IDENTITY=true

# --- AI Search (RAG over data/*.docx) ---
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
SEARCH_CONNECTION_NAME=<your-ai-search-connection-name>
SEARCH_INDEX_NAME=<your-search-index-name>
# Optional API key for AI Search. If unset, AI Search uses DefaultAzureCredential
# (same caveats as Voice Live above).
AZURE_SEARCH_API_KEY=

# --- Observability ---
APPLICATIONINSIGHTS_CONNECTION_STRING=

# NOTE: Docker --env-file does NOT tolerate spaces around `=` (use KEY=VALUE,
# no surrounding spaces, no quotes). python-dotenv is more forgiving, so a
# file that works locally may silently break inside the container.
# Foundry agent model deployment name (used by scripts/setup_foundry_agent.py)
# gpt-5.4-mini balances tool-call accuracy and latency well for the voice
# avatar workload. gpt-4o-mini / gpt-4.1-mini also work; set this to the
# deployment name you created in your Foundry project.
AGENT_MODEL=gpt-5.4-mini

# Reasoning effort for the Foundry agent. Default `medium` (set in
# scripts/setup_foundry_agent.py) is the sweet spot for gpt-5.4-mini:
# strong tool-call accuracy without multi-second pauses. Drop to `low` if
# you need faster TTFB and accept slightly worse routing on ambiguous
# turns. Silently ignored when AGENT_MODEL is a non-reasoning model
# (gpt-4.x / gpt-4o reject reasoning.effort at /responses time).
# Valid values: minimal | low | medium | high
AGENT_REASONING_EFFORT=medium

# Foundry embedding model deployment name (used by scripts/setup_aisearch_index.py
# and scripts/test_aisearch_query.py). After switching embedding models, run
# `RECREATE_INDEX=true uv run python scripts/setup_aisearch_index.py` ONCE to
# drop+rebuild the index — vector dimensions are immutable on existing indexes.
EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ============================================================================
# UI / Behaviour Configuration (UI_*)
# ============================================================================
# Every voice/avatar/turn-detection setting that used to live in the left
# sidebar is now driven from these env vars. The frontend hides the sidebar
# entirely in production (UI_DEVELOPER_MODE=false) and auto-connects on page
# load using the resolved values. Set UI_DEVELOPER_MODE=true to re-enable the
# sidebar locally for ad-hoc tuning; client-supplied values are only honoured
# when developer mode is on.
#
# All UI_* keys are optional. Defaults shown below match the Python defaults
# in backend/config.py:get_ui_config(). The lines stay COMMENTED on purpose —
# uncommenting a line just pins the literal default; you only need to set a
# variable when you want to OVERRIDE the default.
#
# Sections mirror the legacy sidebar layout. Every variable backed by a
# dropdown lists its full allowed set inline so you can reconfigure the app
# without opening any code.

# --- Speech Recognition ---

# Speech recognition model.
# Allowed: azure-speech | mai-transcribe-1
# UI_SR_MODEL=azure-speech

# Recognition language (BCP-47 tag, or "auto" to detect from audio).
# Ignored when UI_SR_MODEL=mai-transcribe-1 — resolver forces "auto" in that case.
# Allowed: auto | en-US | en-GB | en-IN | en-ZA | es-ES | es-MX | fr-FR
#        | de-DE | it-IT | hi-IN | ja-JP | ko-KR | pt-BR | zh-CN
# UI_RECOGNITION_LANGUAGE=auto

# --- Audio Processing ---

# Noise suppression on the input mic stream.
# Allowed: true | false
# UI_USE_NS=true

# Echo cancellation on the input mic stream.
# Allowed: true | false
# UI_USE_EC=true

# --- Turn Detection ---

# How Voice Live decides the user has stopped talking.
# Allowed: azure_semantic_vad | server_vad
# UI_TURN_DETECTION_TYPE=azure_semantic_vad

# Strip "um", "uh", etc. from recognised speech before sending to the agent.
# Allowed: true | false
# UI_REMOVE_FILLER_WORDS=false

# End-of-utterance detection model.
# Allowed: semantic_detection_v1 | semantic_detection_v1_multilingual | none
# UI_EOU_DETECTION_TYPE=semantic_detection_v1

# --- Behaviour ---

# Have the agent speak a proactive greeting as soon as the session connects.
# Allowed: true | false
# UI_ENABLE_PROACTIVE=true

# --- Voice Configuration ---

# Which voice family to use. Each option enables a different field block:
#   standard → UI_VOICE_NAME (preset Neural / Multilingual / DragonHD / OpenAI)
#   custom   → UI_CUSTOM_VOICE_DEPLOYMENT_ID + UI_CUSTOM_VOICE_NAME
#   personal → UI_PERSONAL_VOICE_NAME + UI_PERSONAL_VOICE_MODEL
# The resolver blanks the fields the chosen type doesn't use.
# Allowed: standard | custom | personal
# UI_VOICE_TYPE=standard

# Standard voice (used when UI_VOICE_TYPE=standard).
# Allowed (default marked [*]):
#   DragonHD family —
#     en-us-ava:DragonHDLatestNeural          — Ava (HD)
#     en-us-steffan:DragonHDLatestNeural      — Steffan (HD)
#     en-us-andrew:DragonHDLatestNeural       — Andrew (HD)
#     en-us-andrew2:DragonHDLatestNeural      — Andrew (HD 2)
#     en-us-aria:DragonHDLatestNeural         — Aria (HD)
#     en-us-davis:DragonHDLatestNeural        — Davis (HD)
#     en-us-emma:DragonHDLatestNeural         — Emma (HD)
#     en-us-emma2:DragonHDLatestNeural        — Emma (HD 2)
#     en-us-jenny:DragonHDLatestNeural        — Jenny (HD)
#     de-de-seraphina:DragonHDLatestNeural    — Seraphina (HD)
#     ja-jp-masaru:DragonHDLatestNeural       — Masaru (HD)
#     zh-cn-xiaochen:DragonHDLatestNeural     — Xiaochen (HD)
#   DragonHD Flash family —
#     zh-CN-Xiaoxiao2:DragonHDFlashLatestNeural — Xiaoxiao2 HDFlash
#     zh-CN-Yunyi:DragonHDFlashLatestNeural     — Yunyi HDFlash
#   Multilingual Neural —
#     en-US-AvaMultilingualNeural             — Ava Multilingual
#     en-US-AlloyTurboMultilingualNeural      — Alloy Turbo Multilingual
#     en-US-AndrewMultilingualNeural          — Andrew Multilingual
#     en-US-BrianMultilingualNeural           — Brian Multilingual
#     en-US-EmmaMultilingualNeural            — Emma Multilingual
#     en-US-NovaTurboMultilingualNeural       — Nova Turbo Multilingual
#     zh-CN-XiaoxiaoMultilingualNeural        — Xiaoxiao Multilingual
#   Single-language Neural —
#     en-US-AvaNeural                         — Ava
#     en-US-AndrewNeural                      — Andrew
#     en-US-JennyNeural                       — Jenny
#     en-ZA-LeahNeural                        — Leah (South Africa)  [*]
#     en-ZA-LukeNeural                        — Luke (South Africa)
#     zh-HK-HiuMaanNeural                     — HiuMaan (Cantonese)
#     mt-MT-JosephNeural                      — Joseph (Maltese)
#   OpenAI voices —
#     alloy | ash | ballad | coral | echo | sage | shimmer | verse
# UI_VOICE_NAME=en-ZA-LeahNeural

# Voice temperature — affects expressiveness on DragonHD / personal voices.
# Standard non-HD neural voices ignore this.
# Range: 0.0-1.0 step 0.1
# UI_VOICE_TEMPERATURE=0.9

# Voice speed as a percentage of normal pace (converted to a multiplier
# server-side, e.g. 100 → 1.0, 150 → 1.5).
# Range: 50-150 step 5 (percent)
# UI_VOICE_SPEED=100

# --- Custom Voice (only when UI_VOICE_TYPE=custom; resolver blanks otherwise) ---

# Custom-voice deployment ID in your Azure Speech resource.
# Free text — must match a deployed custom voice in your Speech resource.
# UI_CUSTOM_VOICE_DEPLOYMENT_ID=

# Custom-voice character name (the name you trained the voice under).
# Free text — must match the deployed custom voice name.
# UI_CUSTOM_VOICE_NAME=

# --- Personal Voice (only when UI_VOICE_TYPE=personal; resolver blanks otherwise) ---

# Personal-voice character name.
# Free text — must match a deployed personal voice in your Speech resource.
# UI_PERSONAL_VOICE_NAME=

# Personal-voice model family.
# Allowed: DragonLatestNeural | DragonHDOmniLatestNeural
# UI_PERSONAL_VOICE_MODEL=DragonLatestNeural

# --- Avatar Configuration ---

# Master switch. When false, the avatar pipeline is skipped entirely and the
# UI shows a volume-animation view instead of a video stream.
# Allowed: true | false
# UI_AVATAR_ENABLED=true

# Avatar streaming transport.
# Allowed: webrtc | websocket
# UI_AVATAR_OUTPUT_MODE=webrtc

# Use a photo-realistic avatar (vs. the lower-cost rendered preset avatars).
# Allowed: true | false
# UI_IS_PHOTO_AVATAR=true

# Use a custom-trained avatar character. When true, UI_CUSTOM_AVATAR_NAME is
# REQUIRED (startup validation refuses to boot if it's empty / whitespace).
# Allowed: true | false
# UI_IS_CUSTOM_AVATAR=true

# Standard preset avatar (used only when both UI_IS_CUSTOM_AVATAR=false AND
# UI_IS_PHOTO_AVATAR=false).
# Allowed: Harry-business | Harry-casual | Harry-youthful
#        | Jeff-business | Jeff-formal
#        | Lisa-casual-sitting   [*]
#        | Lori-casual | Lori-formal | Lori-graceful
#        | Max-business | Max-casual | Max-formal
#        | Meg-business | Meg-casual | Meg-formal
# UI_AVATAR_NAME=Lisa-casual-sitting

# Small caption rendered under the avatar video.
# Free text. Leave empty to auto-derive from the effective avatar character
# (e.g. "Lisa-casual-sitting" → "Lisa", "Nuru" → "Nuru").
# UI_AVATAR_DISPLAY_NAME=

# Photo-avatar character (used only when UI_IS_PHOTO_AVATAR=true AND
# UI_IS_CUSTOM_AVATAR=false).
# Allowed (default marked [*]):
#   Adrian | Amara | Amira | Anika [*] | Bianca | Camila | Carlos | Clara
#   Darius | Diego | Elise | Farhan | Faris | Gabrielle | Hyejin | Imran
#   Isabella | Layla | Ling | Liwei | Marcus | Matteo | Rahul | Rana | Ren
#   Riya | Sakura | Simone | Zayd | Zoe
# UI_PHOTO_AVATAR_NAME=Anika

# Custom-trained photo avatar character (used when UI_IS_CUSTOM_AVATAR=true).
# Free text — must match a custom avatar trained against your Speech resource.
# Required when UI_IS_CUSTOM_AVATAR=true (validated at startup).
# UI_CUSTOM_AVATAR_NAME=Nuru

# Background image rendered behind the photo avatar.
# Free text — full URL string. Leave empty for the SDK default.
# UI_AVATAR_BACKGROUND_IMAGE_URL=

# --- Scene Settings (only when UI_IS_PHOTO_AVATAR=true; resolver clears the
#                      photoScene dict when false) ---

# Camera zoom level on the photo avatar (lower = more zoomed in).
# Range: 70-100 step 1 (percent)
# UI_SCENE_ZOOM=100

# Camera horizontal position offset.
# Range: -50 to 50 step 1 (percent of frame width)
# UI_SCENE_POSITION_X=0

# Camera vertical position offset.
# Range: -50 to 50 step 1 (percent of frame height)
# UI_SCENE_POSITION_Y=0

# Camera rotation around the X axis (pitch).
# Range: -30 to 30 step 1 (degrees)
# UI_SCENE_ROTATION_X=0

# Camera rotation around the Y axis (yaw).
# Range: -30 to 30 step 1 (degrees)
# UI_SCENE_ROTATION_Y=0

# Camera rotation around the Z axis (roll).
# Range: -30 to 30 step 1 (degrees)
# UI_SCENE_ROTATION_Z=0

# Mouth-motion amplitude on the photo avatar (lower = more subtle motion).
# Range: 10-100 step 1 (percent)
# UI_SCENE_AMPLITUDE=100

# ----------------------------------------------------------------------------
# Resolver rules (applied server-side in /api/config so the frontend just
# consumes the resolved payload as-is — and re-applied to dev-mode sidebar
# overrides so cascading rules can't be bypassed):
#   1. UI_SR_MODEL=mai-transcribe-1 forces recognitionLanguage="auto"
#      (matches the runtime handler behaviour).
#   2. UI_VOICE_TYPE cascade — the unused custom/personal voice fields are
#      blanked in the resolved config:
#        standard → blanks custom + personal voice fields
#        custom   → blanks personal voice fields
#        personal → blanks custom voice fields
#   3. UI_AVATAR_ENABLED=false does NOT blank the avatar/scene fields. The
#      runtime ignores them when avatar is off, so leaving them populated
#      preserves a clean dev re-enable.
#   4. UI_IS_CUSTOM_AVATAR=true REQUIRES UI_CUSTOM_AVATAR_NAME to be
#      non-empty. Validation runs at app startup so a bad combo prevents
#      the Container App revision from going healthy (auto-rollback).
#      Skipped when UI_AVATAR_ENABLED=false.
#   5. Effective avatarName precedence: custom > photo > standard. The
#      runtime applies the same precedence so dev-mode merges that only
#      touch some avatar fields still produce the right SDK character.
#   6. UI_IS_PHOTO_AVATAR=false → photoScene is emptied to {} in the
#      resolved config.
# ----------------------------------------------------------------------------

# --- UI Layout ---

# Show the legacy sidebar locally for ad-hoc tuning. In dev mode the session
# does NOT auto-connect; you drive Connect/Disconnect manually from the
# sidebar footer, and any sidebar tweaks are merged on top of these env
# defaults per-key (resolver rules are re-applied on the merged payload).
# Production must leave this unset/false so DevTools cannot tamper with the
# session config.
# Allowed: true | false
# UI_DEVELOPER_MODE=false
