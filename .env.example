# --- Required: Voice Live / Foundry ---
AZURE_VOICELIVE_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/
AGENT_NAME=AvatarAgent
AGENT_PROJECT_NAME=avatar-forge
PROJECT_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/api/projects/<project-name>
VOICELIVE_VOICE=en-US-AvaMultilingualNeural

# --- Authentication ---
# Voice Live agent-v2 sessions require Microsoft Entra ID (AAD). API key auth
# is NOT supported for the agent WebSocket path used by this app, so the
# backend always uses DefaultAzureCredential.
#
# Local host (no Docker):  run `az login` - DefaultAzureCredential picks it
#                          up via AzureCliCredential.
#
# Azure (`azd up`):        the Container App uses a user-assigned managed
#                          identity provisioned by the infra. Nothing to set
#                          here. This is the recommended path.
#
# Local Docker:            NOT recommended. The image has no az CLI, no
#                          IMDS, and SP client secrets are typically blocked
#                          by tenant app-management policy (see README
#                          "Authentication inside the container"). If your
#                          tenant DOES allow SP secrets, you can set:
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# Optional: skip the IMDS managed-identity probe in DefaultAzureCredential.
# Set to "true" on a developer laptop to cut startup pre-warm from ~7s to
# ~1.5s. DefaultAzureCredential normally tries ManagedIdentityCredential
# first and waits ~5s for the IMDS endpoint at 169.254.169.254 to time out
# before falling through to AzureCliCredential. Off-Azure that probe never
# succeeds, so skipping it is pure win.
# IMPORTANT: leave UNSET (or "false") in Azure-hosted environments —
# Container Apps, App Service, and AKS workload identity all need the
# managed-identity path enabled.
# AUTH_EXCLUDE_MANAGED_IDENTITY=true

# --- Foundry agent: Grounding-with-Bing-Custom-Search tool ---
# Connection name for the Grounding-with-Bing-Custom-Search resource in your
# Foundry project. Used only by scripts/setup_foundry_agent.py at provisioning
# time; the runtime backend never talks to Bing directly.
BING_CONNECTION_NAME=groundingwithbingcustquraml

# Bing Custom Search configuration (instance) name — the curated allow-list of
# domains the web tool is restricted to. Provisioned in the Bing Custom Search
# portal and referenced here by name.
BING_CUSTOM_CONFIG_NAME=mtn-avatar-search

# --- AI Search (RAG over data/*.docx) ---
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
SEARCH_CONNECTION_NAME=<your-ai-search-connection-name>
SEARCH_INDEX_NAME=<your-search-index-name>
# Optional API key for AI Search. If unset, AI Search uses DefaultAzureCredential
# (same caveats as Voice Live above).
AZURE_SEARCH_API_KEY=

# Optional: override the internal structural names of the search index. These
# are only read by scripts/setup_aisearch_index.py and test_aisearch_query.py
# (NOT by the runtime backend or the agent). Set them only if an existing index
# was built with different names and you want the scripts to stay compatible.
# SEARCH_VECTOR_PROFILE=default-vector-profile
# SEARCH_HNSW_ALGO=default-hnsw
# SEARCH_SEMANTIC_CONFIG=default-semantic
# SEARCH_VECTORIZER=default-vectorizer

# --- Observability ---
APPLICATIONINSIGHTS_CONNECTION_STRING=

# NOTE: Docker --env-file does NOT tolerate spaces around `=` (use KEY=VALUE,
# no surrounding spaces, no quotes). python-dotenv is more forgiving, so a
# file that works locally may silently break inside the container.
# Foundry agent model deployment name (used by scripts/setup_foundry_agent.py).
# Validated configs for voice (see prompts/agent/routing-test-questions.md):
#   * gpt-5.4 + AGENT_REASONING_EFFORT=none      — RECOMMENDED (current production).
#                                                 Best tool-routing accuracy (30/30
#                                                 on the routing harness) and the
#                                                 cleanest synthesis on fiscal-period
#                                                 questions and share-price (cents→rand)
#                                                 conversion.
#   * gpt-5.4-mini + AGENT_REASONING_EFFORT=none — faster first token, but lower
#                                                 routing accuracy and a few synthesis
#                                                 slips; a fine cost-saving fallback.
#   * gpt-4.1-mini                               — the original non-reasoning baseline
#                                                 the ~93.5% tool-accuracy number was
#                                                 first measured on. Kept for reference.
# Set this to the deployment name you created in your Foundry project.
AGENT_MODEL=gpt-5.4

# Reasoning effort for the Foundry agent. The valid values depend on the model:
#   * gpt-4.x / gpt-4o   — leave UNSET. They reject reasoning.effort at /responses
#                          time with `unsupported_parameter` (silent avatar).
#   * gpt-5.x (gpt-5.4 / gpt-5.4-mini) — none | low | medium | high | xhigh
#   * o1 / o3 / o4-mini  — low | medium | high
# For voice latency on the gpt-5.x models the validated value is `none`. Actual
# reasoning steps (low / medium / high) add 4-5 seconds to first-token, which
# is too laggy for conversational avatar use. `none` keeps the synthesis-quality
# benefit of the gpt-5 base model without the per-turn reasoning latency.
# scripts/setup_foundry_agent.py also selects the prompt variant based on this
# model family (reasoning vs non-reasoning) — see prompts/README.md.
AGENT_REASONING_EFFORT=none

# --- Greenfield Foundry model deployment (azd `azd up` provision only) ---
# Read ONLY when azd creates a NEW Foundry model deployment (infra/main.bicep).
# The runtime backend and the agent ignore these. For a brownfield (BYO Foundry)
# deploy they are unused. IMPORTANT: if you change the model you must change the
# version to match — an invalid model/version pair fails the deployment. Keep
# MODEL_DEPLOYMENT_NAME aligned with AGENT_MODEL (the agent binds to it).
# MODEL_NAME=gpt-5.4
# MODEL_VERSION=2026-03-05
# MODEL_DEPLOYMENT_NAME=gpt-5.4

# Retrieval breadth for the Foundry agent tools (used by
# scripts/setup_foundry_agent.py). Both default to 8 if unset — the validated
# production value: it widens the chunk/snippet budget so summary-style
# questions answer more completely, without hurting tool routing or meeting
# scoping. AI_SEARCH_TOP_K = chunks pulled from the meeting-minutes index;
# BING_COUNT = snippets from the Bing Custom Search allow-list.
AI_SEARCH_TOP_K=8
BING_COUNT=8

# Optional: how long (seconds) the backend caches the meeting catalogue it
# fetches from AI Search at session start and injects as a system message.
# Default 900 (15 min). Read only by backend/voice/catalog.py at runtime.
# MEETING_CATALOG_TTL_S=900

# Foundry embedding model deployment name (used by scripts/setup_aisearch_index.py
# and scripts/test_aisearch_query.py). After switching embedding models, run
# `RECREATE_INDEX=true uv run python scripts/setup_aisearch_index.py` ONCE to
# drop+rebuild the index — vector dimensions are immutable on existing indexes.
EMBEDDING_DEPLOYMENT=text-embedding-3-small

DEVELOPER_MODE=false

# --- UI / Session defaults (used when DEVELOPER_MODE=false) ---
# When the sidebar is hidden, the session auto-starts using these values.
# Booleans accept: true/false (also 1/0, yes/no, on/off).
# Each setting lists ALL valid options; uncomment and change to override.

# Speech Recognition model.
#   Options: azure-speech | mai-transcribe-1
#   (mai-transcribe-1.5 is LLM Speech / batch only — not on Voice Live realtime yet.)
# SR_MODEL=mai-transcribe-1

# Recognition language (ignored for MAI Transcribe models, which auto-detect).
#   Options: auto | en-US | zh-CN | de-DE | en-GB | en-IN | en-ZA | es-ES |
#            es-MX | fr-FR | hi-IN | it-IT | ja-JP | ko-KR | pt-BR
# RECOGNITION_LANGUAGE=auto

# Audio pre-processing toggles.
#   Options: true | false
# USE_NOISE_SUPPRESSION=true
# USE_ECHO_CANCELLATION=true

# Turn detection (how the server decides the user stopped talking).
#   Options: server_vad | azure_semantic_vad
# TURN_DETECTION_TYPE=azure_semantic_vad

# Silence (ms) the VAD waits after speech before ending the user's turn.
#   Lower = snappier turns; higher = more tolerant of mid-sentence pauses.
#   Options: 500 | 1000 | 1500 | 2000   (default 500)
# TURN_DETECTION_SILENCE_MS=500

# Barge-in: let the user interrupt the avatar mid-answer by speaking.
#   Controls BOTH the client (stop avatar audio on speech) and the server
#   (interrupt_response). Keep both in sync — do not enable one without the
#   other or the avatar's own echo can hijack turns.
#   Options: true | false   (default true)
# ENABLE_BARGE_IN=true

# Make the Voice Live VAD ignore filler words ("um", "uh", "yeah", …) while
# the avatar is replying, so a small noise from the user doesn't cancel the
# in-flight response. Microsoft's recommended default for barge-in robustness.
#   Options: true | false   (default true)
# REMOVE_FILLER_WORDS=true

# End-of-utterance detector.
#   Options: none | semantic_detection_v1 | semantic_detection_v1_multilingual
# EOU_DETECTION_TYPE=semantic_detection_v1

# Let the agent speak first / interject without being asked.
#   Options: true | false
# ENABLE_PROACTIVE=false

# Verbatim opening line the avatar speaks when ENABLE_PROACTIVE=true. This is
# the only place to put a client-specific persona/greeting; the backend code
# stays generic. Leave unset for a neutral default greeting.
# PROACTIVE_GREETING=Hello, I am your assistant. How can I help you today?

# --- Voice ---
# Voice category.
#   Options: standard | custom | personal
# VOICE_TYPE=standard

# Standard voice name. Override VOICELIVE_VOICE at the top of this file
# instead — both env vars feed the same UI field.
#   Common options: en-ZA-LeahNeural | en-ZA-LukeNeural |
#     en-US-AvaNeural | en-US-AndrewNeural | en-US-JennyNeural |
#     en-US-AvaMultilingualNeural | en-US-EmmaMultilingualNeural |
#     en-us-ava:DragonHDLatestNeural | en-us-andrew:DragonHDLatestNeural |
#     en-us-emma:DragonHDLatestNeural | en-us-jenny:DragonHDLatestNeural |
#     zh-CN-XiaoxiaoMultilingualNeural | zh-HK-HiuMaanNeural |
#     mt-MT-JosephNeural | alloy | ash | ballad | coral | echo | sage |
#     shimmer | verse
#   (see frontend/index.html #voiceName for the full list)

# Speech rate as a percentage of normal.
#   Range: 50 - 150 (step 5)
# VOICE_SPEED=100

# Voice temperature (DragonHD / personal voices only).
#   Range: 0.0 - 1.0
# VOICE_TEMPERATURE=0.9

# --- Avatar ---
# Show the avatar at all.
#   Options: true | false
# AVATAR_ENABLED=true

# Avatar transport.
#   Options: webrtc | websocket
# AVATAR_OUTPUT_MODE=webrtc

# Mutually-exclusive avatar flavours. Pick at most one as true; if both are
# false the standard avatar (AVATAR_NAME) is used.
#   Options: true | false
IS_PHOTO_AVATAR=false
IS_CUSTOM_AVATAR=false

# Standard avatar character (used when IS_PHOTO_AVATAR=false and IS_CUSTOM_AVATAR=false).
#   Options: Harry-business | Harry-casual | Harry-youthful |
#     Jeff-business | Jeff-formal | Lisa-casual-sitting |
#     Lori-casual | Lori-formal | Lori-graceful |
#     Max-business | Max-casual | Max-formal |
#     Meg-business | Meg-casual | Meg-formal
# AVATAR_NAME=Lisa-casual-sitting

# Custom avatar character name (used when IS_CUSTOM_AVATAR=true). Free-text;
# must match a custom avatar provisioned in your Speech resource.
CUSTOM_AVATAR_NAME=

# Assistant persona / display name (e.g. "Nuru"). This is the brand name used in
# the Teams bot's welcome message (issue #53) and as the default --name when
# building the Teams package. It is a DEDICATED, purely cosmetic label and does
# NOT select the avatar model (see AVATAR_NAME / CUSTOM_AVATAR_NAME /
# PHOTO_AVATAR_NAME below). It is intentionally NOT derived from
# CUSTOM_AVATAR_NAME: that is a Speech custom-avatar *model* id, valid only when
# IS_CUSTOM_AVATAR=true. Unset falls back to the neutral "Avatar".
# AVATAR_DISPLAY_NAME=Nuru

# Photo-realistic avatar character (used when IS_PHOTO_AVATAR=true).
#   Options: Adrian | Amara | Amira | Anika | Bianca | Camila | Carlos |
#     Clara | Darius | Diego | Elise | Farhan | Faris | Gabrielle |
#     Hyejin | Imran | Isabella | Layla | Ling | Liwei | Marcus |
#     Matteo | Rahul | Rana | Ren | Riya | Sakura | Simone | Zayd | Zoe
# PHOTO_AVATAR_NAME=Anika

# Optional background image URL behind the avatar. Leave empty for none.
# AVATAR_BACKGROUND_IMAGE_URL=

# Identity tagline shown under the avatar's name (top-left of the stage), e.g.
# the assistant's role. Leave empty to show only the name. Defaults to the
# company-agnostic "Your Digital Assistant"; set this for branded deployments
# (e.g. "Your MTN Digital Assistant").
# AVATAR_TAGLINE=Your Digital Assistant

# ============================================================================
# Avatar UX (live captions, speaking-state colour shift, suggested prompts)
# Additive UI features. Captions are OFF by default; suggested prompts are ON.
# ============================================================================

# Live captions: render a subtitle line under the avatar showing what it is
# saying (and, optionally, the user's last utterance). Reuses the existing
# transcript stream — no extra model calls. Default: false. Set to true to show.
# ENABLE_CAPTIONS=false

# Also show the user's last spoken utterance in the caption band (briefly,
# until the avatar starts answering). Only applies when ENABLE_CAPTIONS=true.
# Default: false.
# CAPTIONS_SHOW_USER=false

# Suggested prompts + onboarding hint shown on first load (before the first
# user turn). Default: true. Set to false to hide the hint and example chips.
# ENABLE_SUGGESTED_PROMPTS=true

# One-line onboarding hint shown above the example chips. Default is
# modality-aware: "Tap the mic or type to ask me anything" when the text
# composer is enabled (ENABLE_TEXT_INPUT=true), otherwise "Tap the mic and ask
# me anything". Set explicitly to override.
# ONBOARDING_HINT=Tap the mic or type to ask me anything

# Pipe-separated list of tappable example questions (2-3 recommended). Tapping
# a chip sends that question through the normal text path.
# SUGGESTED_PROMPTS=What can you help me with?|Tell me about your services|How do I get started?

# Text input composer (normal mode): show a "Type a message…" pill on the
# avatar stage so users can type instead of (or alongside) using the mic.
# Reuses the existing text path; voice stays primary. The field stays disabled
# until the session connects. Default: true. Set to false to hide it (voice
# only). Developer mode is unaffected — it always has its own text input.
# ENABLE_TEXT_INPUT=true


# ===================================================================
# --- Teams conversational bot (issue #53, Phase 2a) ---
# ===================================================================
# These are only needed when running/hosting the Teams bot. The bot reuses the
# same Foundry agent (AGENT_NAME / PROJECT_ENDPOINT above) for answers.
#
# Bot identity — from the Azure Bot registration + its Entra app (see
# teams/README.md). Stored on the Container App by infra (the secret as an ACA
# secret). The CONNECTIONS__* names are the Microsoft 365 Agents SDK convention.
# CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=<bot-app-client-id>
# CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=<bot-app-client-secret>
# CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=<tenant-id>
#
# TEAMS_BOT_ID: the bot's Microsoft App ID (GUID). Also used by
# teams/build_package.py to fill {{BOT_ID}} in the manifest.
# TEAMS_BOT_ID=<bot-app-client-id>
#
# TEAMS_APP_ID: the Teams app (manifest) id, used to build deep links from the
# bot back into the personal tab (#28). Match the id used to build the package.
# TEAMS_APP_ID=<teams-app-id>
# TEAMS_TAB_ENTITY_ID=avatarForgeHome
#
# AGENT_ID: optional override; when empty the agent is resolved by AGENT_NAME.
# AGENT_ID=
#
# BOT_RUN_TIMEOUT_S: max seconds to let a grounded Foundry run execute in the
# background before posting a "took too long" reply. Answers are delivered as a
# proactive message (ack-then-background-run), so this is NOT bound by the Teams
# ~15s turn window — it can safely exceed it.
# BOT_RUN_TIMEOUT_S=60
